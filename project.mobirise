          "_name": "video02",
          "_sourceTheme": "immersem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"video02 immersem5\" group=\"Image & Video\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Height\" name=\"height\" min=\"5\" max=\"12\" step=\"1\" value=\"8\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Frame\" name=\"showFrame\" checked>\n        <input type=\"color\" title=\"Frame Color\" value=\"#ffffff\" name=\"frameColor\" selected condition=\"showFrame\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/fondo-ok333-fotor-enhance-20260508121008.jpg\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/immersem5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#0725fa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.2\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div class=\"container-fluid\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"frame-wrapper\">\n                    <div class=\"content-wrapper\">\n                        <div class=\"content-wrap\">\n                            <p class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                                <b>Something, sometimes</b>\n                            </p>\n                            <div class=\"text-wrap\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrap\">\n                                    As the clouds gracefully glide across the canvas of the sky, they whisper secrets of\n                                    the universe.\n                                </p>\n                            </div>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n\t\t\t\t\t\t\tStart Now\n\t\t\t\t\t\t</a></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vj34neDHxs",
          "_anchor": "video02-b",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".title-wrapper": {
              "position": "relative",
              "z-index": "1",
              "width": "80%",
              "margin": "0 auto",
              "margin-bottom": "82px",
              "@media (max-width: 992px)": {
                "width": "100%",
                "margin-bottom": "28px"
              },
              ".label-wrapper": {
                "margin-bottom": "42px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "28px"
                },
                ".label-wrap": {
                  "padding": "14px 24px",
                  "display": "inline-flex",
                  "align-items": "center",
                  "background-color": "@labelBg",
                  "@media (max-width: 992px)": {
                    "padding": "10px 16px"
                  },
                  ".iconfont-wrapper": {
                    "display": "inline-flex",
                    "margin-right": "14px",
                    ".mbr-iconfont": {
                      "font-size": "19px"
                    }
                  },
                  ".mbr-label": {
                    "margin-bottom": "0"
                  }
                }
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              },
              ".subtitle-wrapper": {
                ".mbr-section-subtitle": {
                  "display": "inline-block",
                  "margin-bottom": "0",
                  "-webkit-text-fill-color": "transparent",
                  "-webkit-background-clip": "text",
                  "background-clip": "text",
                  "background-image": "linear-gradient(90deg, @subtitleGradient_1, @subtitleGradient_2 50%, @subtitleGradient_3)"
                }
              }
            },
            ".items-wrapper": {
              "display": "grid",
              "grid-template-columns": ".9fr 1fr .9fr",
              "gap": "115px",
              "@media (max-width: 1440px)": {
                "gap": "56px"
              },
              "@media (max-width: 992px)": {
                "display": "block"
              },
              ".list-wrapper": {
                "position": "relative",
                "z-index": "2",
                ".list": {
                  "padding": "0",
                  "margin": "0",
                  "list-style-type": "none",
                  ".item-wrap": {
                    "position": "relative",
                    "padding": "18px 24px",
                    "margin-bottom": "14px",
                    "background-color": "@cardBg",
                    "box-shadow": "0 3px 9.1px @cardShadow, 0 1px 29px @cardShadow",
                    "@media (max-width: 992px)": {
                      "margin-bottom": "16px",
                      "padding": "18px"
                    },
                    "& when (@showMarker)": {
                      "padding": "56px 24px 18px 24px",
                      "@media (max-width: 992px)": {
                        "padding": "56px 18px 18px 18px"
                      },
                      "&::before": {
                        "content": "'✓'",
                        "position": "absolute",
                        "top": "18px",
                        "left": "24px",
                        "display": "inline-flex",
                        "align-items": "center",
                        "justify-content": "center",
                        "width": "24px",
                        "height": "24px",
                        "border-radius": "100%",
                        "background-image": "linear-gradient(135deg, @marker_1, @marker_2)",
                        "color": "@markerColor",
                        "font-size": "15px"
                      }
                    },
                    "&:last-child": {
                      "margin-bottom": "0"
                    }
                  }
                }
              },
              ".image-wrapper": {
                "position": "relative",
                "z-index": "1",
                "align-items": "center",
                "& when (@bg-type = 'color')": {
                  "& when (@showGradient)": {
                    ".gradient-wrap": {
                      "position": "absolute",
                      "width": "400px",
                      "height": "400px",
                      "border-radius": "100%",
                      "background-image": "linear-gradient(135deg, @gradient_1 50%, @gradient_2 40%, @gradient_3 0)",
                      "filter": "blur(10rem)",
                      "pointer-events": "none",
                      "@media (max-width: 1440px)": {
                        "width": "300px",
                        "height": "300px"
                      },
                      "@media (max-width: 425px)": {
                        "width": "260px",
                        "height": "260px"
                      }
                    }
                  }
                },
                ".image-wrap": {
                  "position": "relative",
                  "z-index": "2",
                  "width": "475px",
                  "height": "475px",
                  "border-radius": "100%",
                  "overflow": "hidden",
                  "& when (@bg-type = 'color')": {
                    "& when (@showGradient)": {
                      "padding": "10px",
                      "background-image": "linear-gradient(135deg, @gradient_1, @gradient_2 40%, @gradient_3)",
                      "@media (max-width: 992px)": {
                        "padding": "5px"
                      }
                    }
                  },
                  "@media (max-width: 1440px)": {
                    "width": "300px",
                    "height": "300px"
                  },
                  "@media (max-width: 992px)": {
                    "margin": "28px 0"
                  },
                  "@media (max-width: 425px)": {
                    "width": "260px",
                    "height": "260px"
                  },
                  "img": {
                    "width": "100%",
                    "height": "100%",
                    "object-fit": "cover",
                    "border-radius": "100% !important"
                  }
                }
              },
              ".card": {
                "justify-content": "center"
              }
            },
            ".mbr-label, .label-wrapper": {
              "color": "#1a0b54",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#1a0b54",
              "text-align": "center"
            },
            ".mbr-section-subtitle, .subtitle-wrapper": {
              "color": "#1a0b54",
              "text-align": "center"
            },
            ".list": {
              "color": "#1a0b54"
            }
          },
          "_name": "list01",
          "_sourceTheme": "solvem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list01 solvem5\" group=\"List\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\">\n        <input type=\"color\" title=\"Label BG\" value=\"#f9f9f9\" name=\"labelBg\" condition=\"showLabel\" selected>\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\" condition=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"color\" title=\"Gradient 1\" value=\"#0c2c68\" name=\"subtitleGradient_1\" condition=\"showSubtitle\" selected>\n        <input type=\"color\" title=\"Gradient 2\" value=\"#393193\" name=\"subtitleGradient_2\" condition=\"showSubtitle\" selected>\n        <input type=\"color\" title=\"Gradient 3\" value=\"#f92c50\" name=\"subtitleGradient_3\" condition=\"showSubtitle\" selected>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Marker\" name=\"showMarker\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#ffffff\" name=\"markerColor\" condition=\"showMarker\" selected>\n        <input type=\"color\" title=\"Gradient 1\" value=\"#0c2c68\" name=\"marker_1\" condition=\"showMarker\" selected>\n        <input type=\"color\" title=\"Gradient 2\" value=\"#0725fa\" name=\"marker_2\" condition=\"showMarker\" selected>\n        <input type=\"color\" title=\"BG\" value=\"#ffffff\" name=\"cardBg\" selected>\n        <input type=\"color\" title=\"Shadow\" value=\"#eeeeee\" name=\"cardShadow\" selected>\n        <header condition=\"bg.type == 'color'\">Image</header>\n        <input type=\"checkbox\" title=\"Gradient\" name=\"showGradient\" checked condition=\"bg.type == 'color'\">\n        <input type=\"color\" title=\"Gradient Color 1\" value=\"#1c4eff\" name=\"gradient_1\" condition=\"showGradient && bg.type == 'color'\" selected>\n        <input type=\"color\" title=\"Gradient Color 2\" value=\"#393193\" name=\"gradient_2\" condition=\"showGradient && bg.type == 'color'\" selected>\n        <input type=\"color\" title=\"Gradient Color 3\" value=\"#f92c50\" name=\"gradient_3\" condition=\"showGradient && bg.type == 'color'\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/solvem5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/solvem5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"title-wrapper\" mbr-if=\"showTitle || showSubtitle || showLabel\">\n                    <div class=\"label-wrapper\" mbr-if=\"showLabel\">\n                        <div class=\"label-wrap\">\n                            <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                <span mbr-icon class=\"card-icon mbr-iconfont mobi-mbri-features mobi-mbri\" data-app-selector=\".card-icon\" style=\"color: rgb(202, 69, 255); fill: rgb(202, 69, 255);\"></span>\n                            </div>\n                            <p class=\"mbr-label mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-label, .label-wrapper\">\n                                Modern Database\n                            </p>\n                        </div>\n                    </div>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        Beneficios de</h2>\n                    <div class=\"subtitle-wrapper\">\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .subtitle-wrapper\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            convertirte en cristiano</h3>\n                    </div>\n                </div>\n                <div class=\"items-wrapper justify-content-center align-items-center\">\n                    <div class=\"list-wrapper card\">\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                            <li class=\"item-wrap little-radius\"><b>Perdón y Libertad:</b> Se recibe el perdón completo de los pecados, lo que elimina la carga de la culpa y la condenación personal.</li><li class=\"item-wrap little-radius\"><b>Vida Eterna:</b> Existe la esperanza de que la muerte no es el final, sino el inicio de una eternidad junto a Dios.</li>\n                            <li class=\"item-wrap little-radius\"><b>Relación Directa:</b> El acceso a Dios se vuelve personal; ya no es a través de rituales distantes, sino como una amistad íntima con el Creador.</li>\n                            <li class=\"item-wrap little-radius\"><b>Guía del Espíritu Santo:</b> Se recibe al Espíritu Santo como compañero y guía para entender la verdad y tomar mejores decisiones.</li>\n                            <li class=\"item-wrap little-radius\"><b>Paz Interior:</b> Una sensación de calma y tranquilidad que, según la fe, supera cualquier entendimiento humano y no depende de las circunstancias externas.</li>\n                            <li class=\"item-wrap little-radius\"><b>Propósito y Sentido</b>: Saber que Dios tiene una misión específica para cada persona otorga un motivo claro para vivir cada día.</li>\n                        </ul>\n                    </div>\n                    <div class=\"image-wrapper card\">\n                        <div class=\"gradient-wrap\" mbr-if=\"showGradient\"></div>\n                        <div class=\"image-wrap\">\n                            <img src=\"@PROJECT_PATH@/assets/images/gemini-generated-image-11g5vf11g5vf11g5.png\" alt>\n                        </div>\n                    </div>\n                    <div class=\"list-wrapper card\">\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                            <li class=\"item-wrap little-radius\"><b>Esperanza en la Prueba: </b>En momentos de dolor o enfermedad, se mantiene la seguridad de que Dios cuida de sus hijos y tiene el control.</li>\n                            <li class=\"item-wrap little-radius\"><b>Transformación Personal:</b> Se fomenta la lucha contra el egoísmo, promoviendo virtudes como la humildad, la paciencia y la generosidad.</li>\n                            <li class=\"item-wrap little-radius\"><b>Pertenencia a una Familia:</b> Al convertirte en cristiano, pasas a formar parte de una comunidad global (la Iglesia), lo que brinda una red de apoyo y amor fraternal.</li>\n                            <li class=\"item-wrap little-radius\"><b>Dominio Propio: </b>La formación moral ayuda a desarrollar la fuerza de voluntad y la capacidad de resistir impulsos negativos o pecados</li>\n                            <li class=\"item-wrap little-radius\"><b>Bienestar Emocional y Mental:&nbsp;</b>La fe cristiana proporciona herramientas internas para enfrentar los retos cotidianos</li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vj35uNIVeC",
          "_anchor": "list01-d",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".google-map": {
              "height": "30rem",
              "position": "relative",
              "border-radius": "2rem",
              "iframe": {
                "height": "100%",
                "width": "100%",
                "border-radius": "2rem"
              },
              "[data-state-details]": {
                "color": "#6b6763",
                "height": "1.5em",
                "margin-top": "-0.75em",
                "padding-left": "1.25rem",
                "padding-right": "1.25rem",
                "position": "absolute",
                "text-align": "center",
                "top": "50%",
                "width": "100%"
              },
              "&[data-state]": {
                "background": "#e9e5dc"
              },
              "&[data-state=\"loading\"]": {
                "[data-state-details]": {
                  "display": "none"
                }
              }
            },
            ".content-head": {
              "max-width": "800px"
            }
          },
          "_name": "map01",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"map1\" group=\"Maps\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\" checked>\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n\t\t<input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n\t\t<header>Map</header>\n\t\t<input type=\"map\" title=\"Map\" name=\"googleMap\" place-id=\"<iframe src=&quot;https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3800.0074125759024!2d-63.158443399999996!3d-17.7442899!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93f1e7cd223d85b9%3A0xc8011c039bd74cbc!2sIglesia%20de%20Cristo!5e0!3m2!1ses!2sbo!4v1778258253460!5m2!1ses!2sbo&quot; width=&quot;600&quot; height=&quot;450&quot; style=&quot;border:0;&quot; allowfullscreen=&quot;&quot; loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>\" value=\"<iframe src=&quot;https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3800.0074125759024!2d-63.158443399999996!3d-17.7442899!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93f1e7cd223d85b9%3A0xc8011c039bd74cbc!2sIglesia%20de%20Cristo!5e0!3m2!1ses!2sbo!4v1778258253460!5m2!1ses!2sbo&quot; width=&quot;600&quot; height=&quot;450&quot; style=&quot;border:0;&quot; allowfullscreen=&quot;&quot; loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n\t\t</fieldset>\n\t\t<header condition=\"bg.type === 'video'\">Fallback Image</header>\n\t\t<input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n\t</mbr-parameters>\n\t<div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\t<div mbr-class=\"{'container': !fullWidth}\">\n\t\t<div class=\"row justify-content-center\">\n\t\t\t<div class=\"col-12 content-head\">\n\t\t\t\t<div class=\"mbr-section-head mb-5\" mbr-if=\"showTitle || showSubtitle\">\n\t\t\t\t\t<h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n\t\t\t\t\t\t<b>Our office</b>\n\t\t\t\t\t</h3>\n\t\t\t\t\t<h4 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n\t\t\t\t\t\tFind us here\n\t\t\t\t\t</h4>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"google-map\" mbr-map=\"googleMap\"></div>\n\t</div>\n</section>",
          "_cid": "vj2ZNEyVRE",
          "_anchor": "map01-6",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afooter2",
          "_sourceTheme": "charitym5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer2 charitym5\" group=\"Footers\" global once=\"footers\" mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/charitym5/components/_images/background3.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#f92c50\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f6f6f6\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div class=\"container\">\n        <div class=\"media-container-row align-center mbr-white\">\n            <div class=\"col-12\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style align-center\" mbr-theme-style=\"display-4\" data-app-selector=\".media-container-row .mbr-text\" data-app-placeholder=\"Type Text\">Derechos Reservados Copyright 2026 © Iglesia de Cristo SCZ - Desing By Linestar</p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-text": {
              "color": "#303030"
            },
            ".media-container-row .mbr-text": {
              "color": "#ffffff"
            }
          },
          "_cid": "vj33MlEYJa",
          "_anchor": "afooter2-a",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        }
      ]
    },
    "Contacto.html": {
      "settings": {
        "title": "Iglesia de Cristo I Contacto",
        "meta_descr": "",
