                "top": "-45% !important"
              }
            },
            ".text_widget": {
              "margin-bottom": "32px",
              "a": {
                "transition": "all 0.3s ease-out",
                "&:hover, &:focus": {
                  "opacity": ".8"
                }
              }
            },
            "@media (min-width: 992px)": {
              ".navbar-nav.nav-dropdown": {
