      },
      {
        "css": "'Bungee', display",
        "name": "Bungee",
        "url": "https://fonts.googleapis.com/css?family=Bungee:400"
      },
      {
        "css": "'Cinzel', serif",
        "name": "Cinzel",
        "url": "https://fonts.googleapis.com/css?family=Cinzel:400,500,600,700,800,900"
      },
      {
        "css": "'Poppins', sans-serif",
        "name": "Poppins",
        "url": "https://fonts.googleapis.com/css?family=Poppins:100,100i,200,200i,300,300i,400,400i,500,500i,600,600i,700,700i,800,800i,900,900i"
      }
    ],
    "mcSmartCart": {
      "currency": "USD"
    },
    "uniqCompNum": 61,
    "versionPublish": "6.1.12",
    "screenshot": "screenshot.png",
