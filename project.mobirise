                "transition": "all 0.3s ease-in-out",
                "&:hover, &:focus": {
                  "color": "@activeItems"
                }
              },
              ".mbr-email": {
                "margin-bottom": "0",
                "transition": "all 0.3s ease-in-out",
                "&:hover, &:focus": {
                  "color": "@activeItems"
                }
              }
            },
            ".navbar-caption": {
