              },
              ".nav-link": {
                "transition": "all 0.5s ease-out",
                "border-radius": "4rem !important",
                "border": "1px solid transparent",
                "position": "relative",
                "opacity": "1",
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "bottom": "0",
                  "left": "0",
