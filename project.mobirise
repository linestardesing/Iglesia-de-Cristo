        "dangerColor": "#ffea64",
        "mainFont": "Inter Tight",
        "display1Font": "Cinzel",
        "display1Size": "2",
        "display2Font": "Cinzel",
        "display2Size": 4,
        "display5Font": "Poppins",
        "display5Size": "1",
        "display7Font": "Oswald",
        "display7Size": 1.4,
        "display4Font": "Fjalla One",
        "display4Size": "1",
        "isRoundedImages": true,
        "isRoundedButtons": true,
        "isLargeButtons": true,
        "isGhostButtonBorder": true,
        "underlinedLinks": false,
        "isAnimatedOnScroll": false,
        "isScrollToTopButton": false
      },
      "additionalSetColors": [
        "#0725fa",
        "#404349"
      ]
    },
