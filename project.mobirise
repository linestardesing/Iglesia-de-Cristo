              "@media (max-width: 991px)": {
                "min-width": "auto",
                "max-width": "100%",
                "margin": "1rem 0 1rem 0"
              }
            },
            ".mbr-section-btn-main": {
              "@media (max-width: 991px)": {
                "margin-top": "1rem"
              },
              ".btn": {
                "padding": "10px 64px",
                "margin": "8px",
