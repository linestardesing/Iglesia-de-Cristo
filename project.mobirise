            },
            ".mbr-phone": {
              "color": "#0725fa"
            },
            ".mbr-email": {
              "color": "#0c2c68"
            },
            ".mbr-section-subtitle, .text_widget, .mbr-section-btn": {
              "text-align": "center"
            },
            "a[class*=\"text-\"]:not(.nav-link):not(.dropdown-item):not([role]):not(.navbar-caption):hover": {
              "background-image": "none"
            }
          },
          "_name": "menu01",
          "_sourceTheme": "flavorm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu01 flavorm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\" checked>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"1\" max=\"6\" step=\"0.1\" value=\"6\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" condition=\"false\">\n        <input type=\"color\" title=\"Active Color\" name=\"activeItems\" value=\"#ff543d\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcons\">\n        <input type=\"range\" title=\"Amount\" name=\"iconsAmount\" min=\"1\" max=\"2\" step=\"1\" value=\"2\" condition=\"showIcons\">\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#ffffff\" condition=\"showIcons\">\n        <input type=\"color\" title=\"Icons BG\" name=\"iconsBg\" value=\"#f92c50\" condition=\"showIcons\">\n        <input type=\"checkbox\" title=\"Contacts\" name=\"showContacts\" checked>\n        <input type=\"checkbox\" title=\"Phone\" name=\"showPhone\" condition=\"showContacts\" checked>\n        <input type=\"checkbox\" title=\"Email\" name=\"showEmail\" condition=\"showContacts\" checked>\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\" condition=\"false\">\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\">\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"1\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color Menu\" name=\"menuBgColor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Hamburger Container\" name=\"hamburger\" value=\"#ff8576\">\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n        <div class=\"menu_box\" mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n            <div class=\"navbar-brand d-flex\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"https://mobiri.se\">\n                        <img src=\"@PROJECT_PATH@/assets/images/idc-5to-logo-1.png\" alt=\"Mobirise\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove\">\n                    <a class=\"navbar-caption\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\"><b>FlavorM5</b>\n                    </a>\n                </span>\n                <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n                    <div class=\"hamburger\">\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                    </div>\n                </button>\n            </div>\n            <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n                <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-7\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n                        <a class=\"nav-link link text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Inicio</a>\n                    </li>\n                    <li class=\"nav-item\">\n                        <a class=\"nav-link link text-primary\" href=\"Nosotros.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Nosotros</a>\n                    </li>\n                    <li class=\"nav-item\">\n                        <a class=\"nav-link link text-primary\" href=\"Estudios.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Estudios Biblicos</a>\n                    </li><li class=\"nav-item\"><a class=\"nav-link link text-primary\" href=\"Social.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Labor Social</a></li><li class=\"nav-item\"><a class=\"nav-link link text-primary\" href=\"https://mobirise.com\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Galeria</a></li><li class=\"nav-item\"><a class=\"nav-link link text-primary\" href=\"Contacto.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Contacto</a></li></ul>\n                <div class=\"contacts-wrapper\" mbr-if=\"showContacts\">\n                    <a href=\"#\">\n                        <p class=\"mbr-phone mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showPhone\" data-app-selector=\".mbr-phone\">Av. Alemana 5to anillo Calle José Bruno</p>\n                    </a>\n                    <a href=\"#\">\n                        <p class=\"mbr-email mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showEmail\" data-app-selector=\".mbr-email\">idc.5toanillo@gmail.com</p>\n                    </a>\n                </div>\n                <div class=\"icons-menu-main\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-globe-2 mobi-mbri\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                    </a>\n                </div>\n                <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn-main\" mbr-if=\"showButtons\" role=\"tablist\">\n                    <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        Order now\n                    </a>\n                </div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_cid": "vj3ArsGrPf",
          "_anchor": "menu01-11",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".image-wrap": {
              "height": "400px",
              "@media (max-width: 992px)": {
                "height": "300px"
              }
            }
          },
          "_name": "image01",
          "_sourceTheme": "rebootm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"image01 rebootm5\" group=\"Image & Video\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"12\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/gemini-generated-image-wcfnv9wcfnv9wcfn-1.png\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/rebootm5/components/_images/background2.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#121212\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 card\">\n                <div class=\"image-wrap\"></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vj3Arra27O",
          "_anchor": "image01-10",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background": "linear-gradient(to bottom, @bg1, @bg2)",
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".card-link": {
              "position": "relative",
              "width": "fit-content",
              "&:before": {
                "content": "''",
                "position": "absolute",
                "width": "100%",
                "transition": "all 0.3s",
                "height": "1px",
                "background": "currentColor",
                "left": "0",
                "bottom": "0"
              }
            },
            ".mbr-section-subtitle": {
              "position": "relative",
              "width": "fit-content",
              "padding-left": "35px",
              "display": "inline-block",
              "&:before": {
                "content": "''",
                "width": "12px",
                "height": "12px",
                "border-radius": "50%",
                "background": "currentColor",
                "position": "absolute",
                "left": "10px",
                "top": "~\"calc(50% - 6px)\""
              },
              "text-align": "left"
            },
            ".item-wrapper": {
              "margin-bottom": "0rem",
              "padding": "2.5rem 2rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "0rem",
                "padding": "1rem"
              },
              "margin-top": "2rem",
              "background": "@cardbg",
              "transition": "all 0.3s",
              "&:hover": {
                "background": "@iconColor",
                "transform": "translateY(-5px)",
                ".card-title, .card-text": {
                  "color": "white !important"
                },
                "span, .card-link, .card-link a": {
                  "color": "@primaryColor !important"
                },
                ".card-link:before": {
                  "width": "0%"
                }
              }
            },
            ".card-title, .card-text, .card-link, .card-link a": {
              "transition": "all 0.3s"
            },
            ".link-wrapper": {
              "display": "inline-flex",
              "align-items": "center",
              ".link-icon": {
                "color": "currentColor",
                "font-size": "1rem",
                "padding-left": ".5rem",
                "padding-bottom": "4px",
                "transition": "all 0.3s"
              },
              "&:hover": {
                "cursor": "pointer"
              }
            },
            ".iconfont-wrapper .mbr-iconfont": {
              "display": "inline-flex",
              "font-size": "4rem",
              "color": "@iconColor",
              "justify-content": "center",
              "align-items": "center",
              "transition": "all 0.3s",
              "margin-bottom": "1.5rem",
              "@media (max-width: 767px)": {
                "font-size": "4rem"
              }
            },
            ".card-title, .iconfont-wrapper": {
              "color": "#000000"
            },
            ".card-text": {
              "color": "#232323"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".card-link, .link-icon, .link-align": {
              "color": "#232323"
            },
            ".mbr-section-subtitle, .align": {
              "color": "#232323",
              "text-align": "center"
            }
          },
          "_name": "contacts1",
          "_sourceTheme": "powerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"powerm5 contacts1\" group=\"Contact\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n        <header>Card</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcon\" checked>\n        <input type=\"checkbox\" name=\"showlinks\" title=\"Links\">\n        <input type=\"color\" title=\"Icon/Hover Color\" name=\"iconColor\" value=\"#7787a5\" selected condition=\"showIcon\">\n        <input type=\"color\" title=\"Card BG\" name=\"cardbg\" value=\"#ffffff\" selected condition=\"showIcon\">\n        <select title=\"Columns\" name=\"columns\">\n            <option value=\"12\">1</option>\n            <option value=\"6\">2</option>\n            <option value=\"4\">3</option>\n            <option value=\"3\" selected>4</option>\n        </select>\n        <header>Background</header>\n        <input type=\"color\" name=\"bg1\" title=\"Color 1\" value=\"#0c2c68\">\n        <input type=\"color\" name=\"bg2\" title=\"Color 2\" value=\"#ffffff\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center mb-4\" mbr-if=\"showMainTitle || showMainSubtitle\">\n            <div class=\"col-12 mb-0 content-head\">\n                <div class=\"align w-100\">\n                    <h1 class=\"mbr-section-subtitle mbr-fonts-style mbr-white mb-3\" data-app-selector=\".mbr-section-subtitle, .align\" mbr-theme-style=\"display-2\" mbr-if=\"showMainSubtitle\">CONTACT\n                    </h1>\n                </div>\n\n                <h3 class=\"mbr-section-title mbr-fonts-style align-center\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\">Contacto</h3>\n            </div>\n        </div>\n        <div class=\"row justify-content-center\">\n            <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"iconfont-wrapper mb-3\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mdi-communication-email\"></span>\n                        </div>\n                        <h5 class=\"card-title mbr-fonts-style pb-4\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">Escribenos</h5>\n                        <p class=\"card-text mbr-fonts-style mb-3\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">idc.5toanillo@gmail.com</p>\n\n                        <div class=\"link-align w-100\" mbr-if=\"showlinks\">\n                            <div class=\"link-wrapper\">\n                                <h6 class=\"card-link mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card-link, .link-icon, .link-align\">\n                                    Read More</h6>\n\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"iconfont-wrapper mb-3\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-users mobi-mbri\"></span>\n                        </div>\n                        <h5 class=\"card-title mbr-fonts-style pb-4\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">Chat de Ayuda</h5>\n                        <p class=\"card-text mbr-fonts-style mb-3\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">WhatsApp: 00000 0000<br>Telegram: 0000 0000</p>\n\n                        <div class=\"link-align w-100\" mbr-if=\"showlinks\">\n                            <div class=\"link-wrapper\">\n                                <h6 class=\"card-link mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card-link, .link-icon, .link-align\">\n                                    Read More\n                                </h6>\n\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"iconfont-wrapper mb-3\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-map-pin mobi-mbri\"></span>\n                        </div>\n                        <h5 class=\"card-title mbr-fonts-style pb-4\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                            Visitanos</h5>\n                        <p class=\"card-text mbr-fonts-style mb-3\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Av. Alemana 5to anillo Calle José Bruno N°15<br>Santa Cruz de la Sierra - Bolivia</p>\n\n                        <div class=\"link-align w-100\" mbr-if=\"showlinks\">\n                            <div class=\"link-wrapper\">\n                                <h6 class=\"card-link mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card-link, .link-icon, .link-align\">\n                                    <a href=\"#\" class=\"text-black\">Read More</a>\n                                </h6>\n\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-without-image col-12 col-md-6 col-lg-{{columns}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"iconfont-wrapper mb-3\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-phone mobi-mbri\"></span>\n                        </div>\n                        <h5 class=\"card-title mbr-fonts-style pb-4\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                            Llamanos</h5>\n                        <p class=\"card-text mbr-fonts-style mb-3\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n                            0000-0000<br>0000-0000<br></p>\n\n                        <div class=\"link-align w-100\" mbr-if=\"showlinks\">\n                            <div class=\"link-wrapper\">\n                                <h6 class=\"card-link mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card-link, .link-icon, .link-align\">\n                                    <a href=\"#\" class=\"text-black\">Read More</a>\n                                </h6>\n\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n\n\n        </div>\n    </div>\n</section>",
          "_cid": "vj3GqtFvot",
          "_anchor": "contacts1-1c",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
